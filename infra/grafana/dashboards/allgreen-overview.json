{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(allgreen_http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Request Latency p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(allgreen_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(allgreen_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p50 {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "title": "Scoring Pipeline Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(allgreen_scoring_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Pipeline p99"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(allgreen_scoring_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Pipeline p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "title": "Model Inference Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(allgreen_lstm_inference_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "LSTM p99"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(allgreen_xgboost_inference_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "XGBoost p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Model AUC (Drift Monitor)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "allgreen_model_auc",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0.5,
          "max": 1.0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0.5 },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "Risk Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(allgreen_risk_score_bucket[5m])) by (le)",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Friction Applied (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(allgreen_friction_applied_total[5m])) by (friction_type) * 60",
          "legendFormat": "{{friction_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "HTTP Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(allgreen_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(allgreen_http_requests_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Cases Resolved",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 22 },
      "targets": [
        {
          "expr": "sum(allgreen_cases_resolved_total) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "title": "Rate Limit Rejections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(allgreen_http_requests_total{status=\"429\"}[5m])) * 60",
          "legendFormat": "429s/min"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["allgreen", "fraud-detection"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AllGreen Fraud Detection — Overview",
  "uid": "allgreen-overview",
  "version": 1
