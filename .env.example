# Copy this to .env and fill in real values. Don't commit .env.

# --- Database ---
POSTGRES_URL=postgresql+psycopg://allgreen:changeme@postgres:5432/allgreen
POSTGRES_DB=allgreen
POSTGRES_USER=allgreen
POSTGRES_PASSWORD=changeme

# --- Redis (session feature store + celery broker) ---
REDIS_URL=redis://redis:6379/0

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- API ---
API_SECRET_KEY=change-me-to-something-long-and-random
API_PORT=8000
API_ENV=dev            # dev | staging | prod
LOG_LEVEL=INFO

# --- Model paths (resolved inside the container) ---
LSTM_MODEL_PATH=/app/ml/lstm/artifacts/model.pt
XGBOOST_MODEL_PATH=/app/ml/xgboost/artifacts/model.json

# --- Optional: fraud graph DB (phase 3+) ---
GRAPH_DB_URL=bolt://neo4j:7687
GRAPH_DB_ENABLED=false

# --- Feature flags ---
PERSONALIZED_LSTM_ENABLED=true
MIN_SESSIONS_FOR_PERSONALIZED=50
